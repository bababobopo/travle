# Google Apps Script (GAS) Web App URL
# This is the primary API endpoint for reading/writing itinerary data and uploading images to Google Drive.
GOOGLE_GAS_URL="YOUR_GAS_WEB_APP_URL"

# GAS API Token for authentication
# Must match the API_TOKEN set in your Google Apps Script.
GOOGLE_GAS_TOKEN="YOUR_GAS_SECRET_TOKEN"

# Frontend Access Control (Minimalist)
# This is the "key" users must enter to view the itinerary.
VITE_ACCESS_CODE="2026travel"
